<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

    <!-- Per-row button shared by every visible entry in the inspector.
         Two FontStrings: key column on the left, value column on the
         right. Highlight texture marks the hover row; click drills if
         the value is a table. -->
    <Button name="TableInspectorRowTemplate" virtual="true">
        <Size x="440" y="16"/>
        <Layers>
            <Layer level="ARTWORK">
                <FontString name="$parentKey" inherits="GameFontHighlightSmall" justifyH="LEFT">
                    <Size x="160" y="16"/>
                    <Anchors>
                        <Anchor point="TOPLEFT"/>
                        <Anchor point="BOTTOMLEFT"/>
                    </Anchors>
                </FontString>
                <FontString name="$parentValue" inherits="GameFontHighlightSmall" justifyH="LEFT">
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeTo="$parentKey" relativePoint="TOPRIGHT">
                            <Offset x="6" y="0"/>
                        </Anchor>
                        <Anchor point="BOTTOMRIGHT"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <Scripts>
            <OnLoad>
                self:GetHighlightTexture():SetAlpha(.15);
            </OnLoad>
            <OnClick>TableInspectorRow_OnClick(self);</OnClick>
        </Scripts>
        <HighlightTexture file="Interface\Buttons\UI-Common-MouseHilight" setAllPoints="true" alphaMode="ADD">
            <Color r=".8" g=".8" b="1" a="1"/>
        </HighlightTexture>
    </Button>

    <Frame name="TableInspectorFrame" parent="UIParent" movable="true" hidden="true" frameStrata="MEDIUM" toplevel="true">
        <Size x="480" y="464"/>
        <Anchors>
            <Anchor point="CENTER"/>
        </Anchors>
        <Backdrop bgFile="Interface\DialogFrame\UI-DialogBox-Background" edgeFile="Interface\Tooltips\UI-Tooltip-Border" tile="true">
            <BackgroundInsets>
                <AbsInset left="5" right="5" top="5" bottom="5"/>
            </BackgroundInsets>
            <TileSize>
                <AbsValue val="16"/>
            </TileSize>
            <EdgeSize>
                <AbsValue val="16"/>
            </EdgeSize>
        </Backdrop>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture name="$parentTitleBG" file="Interface\QuestFrame\UI-QuestLogTitleHighlight">
                    <Size x="454" y="20"/>
                    <Anchors>
                        <Anchor point="TOP">
                            <Offset x="0" y="-6"/>
                        </Anchor>
                    </Anchors>
                    <Color r=".6" g=".6" b=".6" a=".4"/>
                </Texture>
            </Layer>
            <Layer level="OVERLAY">
                <FontString name="$parentTitle" inherits="GameFontNormal" text="Table Inspector">
                    <Anchors>
                        <Anchor point="TOP">
                            <Offset x="0" y="-8"/>
                        </Anchor>
                    </Anchors>
                </FontString>
                <!-- Breadcrumb showing the active navigation path,
                     e.g. "_G > MyFrame > backdrop". Updated each
                     `TableInspectorFrame_Update` tick. -->
                <FontString name="$parentBreadcrumb" inherits="GameFontHighlightSmall" justifyH="LEFT">
                    <Size x="380" y="16"/>
                    <Anchors>
                        <Anchor point="TOPLEFT">
                            <Offset x="80" y="-34"/>
                        </Anchor>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
        <Frames>
            <Button name="$parentCloseButton" inherits="UIPanelCloseButton">
                <Anchors>
                    <Anchor point="TOPRIGHT">
                        <Offset x="-2" y="-2"/>
                    </Anchor>
                </Anchors>
                <Scripts>
                    <OnClick>TableInspector_Close();</OnClick>
                </Scripts>
            </Button>
            <Frame name="$parentTitleButton">
                <Size x="280" y="20"/>
                <Anchors>
                    <Anchor point="TOP">
                        <Offset x="0" y="-6"/>
                    </Anchor>
                </Anchors>
                <Scripts>
                    <OnLoad>
                        self:RegisterForDrag("LeftButton");
                    </OnLoad>
                    <OnDragStart>
                        TableInspectorFrame:StartMoving();
                    </OnDragStart>
                    <OnDragStop>
                        TableInspectorFrame:StopMovingOrSizing();
                    </OnDragStop>
                </Scripts>
            </Frame>
            <Button name="$parentBackButton" inherits="UIPanelButtonTemplate" text="&lt; Back">
                <Size x="60" y="20"/>
                <Anchors>
                    <Anchor point="TOPLEFT">
                        <Offset x="12" y="-32"/>
                    </Anchor>
                </Anchors>
                <Scripts>
                    <OnClick>TableInspector_Back();</OnClick>
                </Scripts>
            </Button>
            <Slider name="$parentScroll" orientation="VERTICAL">
                <Size x="16" y="0"/>
                <Anchors>
                    <Anchor point="TOPRIGHT">
                        <Offset x="-7" y="-56"/>
                    </Anchor>
                    <Anchor point="BOTTOMRIGHT">
                        <Offset x="-7" y="10"/>
                    </Anchor>
                </Anchors>
                <Layers>
                    <Layer level="BACKGROUND">
                        <Texture name="$parentBG" setAllPoints="true">
                            <Color r=".8" g=".8" b="1" a="0.1"/>
                        </Texture>
                    </Layer>
                </Layers>
                <Scripts>
                    <OnLoad>
                        self:SetFrameLevel(self:GetFrameLevel() + 1);
                        self:SetMinMaxValues(0, 1);
                        self:SetValue(0);
                        self:SetValueStep(1);
                    </OnLoad>
                    <OnValueChanged>
                        TableInspectorFrame_Update();
                    </OnValueChanged>
                </Scripts>
                <ThumbTexture name="$parentThumb" file="Interface\Buttons\UI-ScrollBar-Knob">
                    <Size x="16" y="16"/>
                    <TexCoords left="0.25" right="0.75" top="0.25" bottom="0.75"/>
                </ThumbTexture>
            </Slider>
        </Frames>
        <Scripts>
            <OnLoad>TableInspectorFrame_OnLoad(self);</OnLoad>
        </Scripts>
    </Frame>

</Ui>
